# Docker Compose local defaults. Copy this file to .env to override them.
DB_NAME=subscription
DB_USERNAME=application
DB_PASSWORD=application
MYSQL_ROOT_PASSWORD=local-root-password
MYSQL_PORT=3306
SERVER_PORT=8080

# Reserved for the subscription history summary feature.
AI_CHAT_PROVIDER=none
OPENAI_API_KEY=
SUBSCRIPTION_HISTORY_AI_MODEL=gpt-5.6-luna
SUBSCRIPTION_HISTORY_AI_MODEL_PROFILE=REASONING
SUBSCRIPTION_HISTORY_AI_TEMPERATURE=0.0
SUBSCRIPTION_HISTORY_AI_MAX_OUTPUT_TOKENS=600
SUBSCRIPTION_HISTORY_AI_MAX_HISTORY_ITEMS=100
SUBSCRIPTION_HISTORY_AI_REASONING_EFFORT=LOW
SUBSCRIPTION_HISTORY_AI_MAX_CONCURRENT_CALLS=8
SUBSCRIPTION_HISTORY_AI_PROMPT_CACHE_KEY=subscription-history-summary-v1
SUBSCRIPTION_HISTORY_AI_TIMEOUT=3s
SUBSCRIPTION_HISTORY_AI_MAX_RETRIES=0
